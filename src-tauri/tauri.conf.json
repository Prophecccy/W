{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "W",
  "version": "0.2.8",
  "identifier": "com.redre.w-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "W",
        "decorations": false,
        "width": 800,
        "height": 600,
        "visible": false
      },
      {
        "label": "sticky-overlay",
        "title": "",
        "url": "/sticky-canvas",
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "maximized": true,
        "visible": false,
        "skipTaskbar": true,
        "focus": false,
        "focusable": false,
        "alwaysOnTop": false,
        "closable": false,
        "resizable": false
      },
      {
        "label": "alarm-popup",
        "title": "Alarm",
        "url": "/alarm-popup",
        "decorations": false,
        "width": 600,
        "height": 400,
        "center": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "widget",
        "title": "W Widget",
        "url": "/widget",
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "width": 460,
        "height": 620,
        "minWidth": 300,
        "minHeight": 400,
        "maxWidth": 800,
        "maxHeight": 900,
        "visible": false,
        "skipTaskbar": true,
        "resizable": true,
        "focusable": false,
        "focus": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.firebaseapp.com https://*.googleapis.com https://*.google.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.firebaseapp.com https://*.googleapis.com; connect-src 'self' https://*.firebaseio.com https://*.googleapis.com https://*.firebasestorage.app https://*.google.com https://*.gstatic.com wss://*.firebaseio.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://firestore.googleapis.com https://github.com; img-src 'self' data: blob: asset: http://asset.localhost https://*.googleusercontent.com https://*.firebasestorage.app; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; media-src 'self' asset: http://asset.localhost; frame-src https://*.firebaseapp.com https://accounts.google.com",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/header.bmp",
        "sidebarImage": "icons/sidebar.bmp"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY4NkIyMDI5QUQwM0E4RTcKUldUbnFBT3RLU0JyYU1paE1NMktXWmk2RlFwUjVrNmJ1TWE0dkpmVXgyRnhTaVhBWXN6TTQrakUK",
      "endpoints": [
        "https://github.com/Prophecccy/W/releases/latest/download/latest.json"
      ]
    }
  }
}
